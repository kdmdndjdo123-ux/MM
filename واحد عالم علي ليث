<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة MM التعليمية</title>
    <script src="https://cdn.jsdelivr.net/npm/lucide@0.344.0/dist/umd/lucide.min.js"></script>
    <style>
        :root { --bg-main: #0b111e; --primary: #00d2ff; --text-main: #ffffff; }
        body { background-color: var(--bg-main); color: var(--text-main); font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .container { text-align: center; background: #151f32; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        input { padding: 15px; border-radius: 10px; border: none; width: 250px; text-align: center; margin-bottom: 15px; }
        button { padding: 15px 30px; border-radius: 10px; border: none; background: var(--primary); font-weight: bold; cursor: pointer; }
    </style>
</head>
<body>
    <div class="container">
        <h1>أهلاً بك في منصة MM</h1>
        <p>أدخل كود التفعيل للدخول:</p>
        <input type="text" id="code" placeholder="أدخل الكود">
        <br>
        <button onclick="check()">دخول</button>
        <p id="msg"></p>
    </div>
    <script>
        function check() {
            let code = document.getElementById('code').value;
            if(code === "123") {
                window.location.href = "https://kdmdndjdo123-ux.github.io/MM/";
            } else {
                document.getElementById('msg').innerHTML = "الكود غير صحيح!";
            }
        }
    </script>
</body>
</html>
